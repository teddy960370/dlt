# 複製成 .env 後填入實際連線資訊（.env 已被 .gitignore 忽略）
#
# 來源連線變數以「實例名稱（大寫）」為前綴，須與 config/sources.yml 的 key 一致。
# 要新增來源實例：複製對應 type 的區塊，改前綴名稱即可（程式不用改）。

# ===== MSSQL 型實例範例（前綴 = sources.yml 的 key，如 MSSQL1、MSSQL2）=====
MSSQL1_HOST=
MSSQL1_PORT=1433
MSSQL1_DATABASE=
MSSQL1_USER=
MSSQL1_PASSWORD=
MSSQL1_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# ===== Oracle 型實例範例（如 ORACLE1、ORACLE2）=====
ORACLE1_HOST=
ORACLE1_PORT=1521
ORACLE1_SERVICE_NAME=
ORACLE1_USER=
ORACLE1_PASSWORD=

# ===== ClickHouse（單一目的地）=====
CLICKHOUSE_HOST=
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false
