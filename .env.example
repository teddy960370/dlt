# 複製成 .env 後填入實際連線資訊（.env 已被 .gitignore 忽略）
#
# 來源連線變數以「實例名稱（大寫）」為前綴，須與 config/sources.yml 的 key 一致。
# 要新增來源實例：複製對應 type 的區塊，改前綴名稱即可（程式不用改）。

# ===== MSSQL 型實例範例（前綴 = sources.yml 的 key，如 ERP、MSSQL2）=====
IMS_HOST=
IMS_PORT=1433
IMS_DATABASE=
IMS_USER=
IMS_PASSWORD=
IMS_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# ===== Oracle 型實例範例（如 MES、ORACLE2）=====
ERP_HOST=
ERP_PORT=1521
ERP_SERVICE_NAME=
ERP_USER=
ERP_PASSWORD=

# Oracle 11g 須用 thick 模式：指向「64 位元」Oracle Client（含 oci.dll）目錄。
# 搭配 oracledb 2.5.1（requirements 已 pin），可用機器上的 12.2 client 連 11g。
# 此為整個程式的全域設定（所有 Oracle 來源共用）。留空則改用系統 PATH 尋找。
ORACLE_CLIENT_LIB_DIR=D:\oracle_client\12.2.0\64\product\12.2.0\client_1

# ===== ClickHouse（單一目的地）=====
# CLICKHOUSE_DATABASE 是 bootstrap/管理用的既有資料庫（通常 default），
# 用來執行 CREATE DATABASE。各來源實際落地的 database 由 sources.yml 的
# target_schema 決定（如 raw_erp），程式會自動建立。
CLICKHOUSE_HOST=
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false
